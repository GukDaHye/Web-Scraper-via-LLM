{
  "manifest_version": 3,
  "name": "Web Scraper via LLM",
  "version": "1.0.0",
  "description": "Scrapes selected elements on web pages and structures them using LLM",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["result.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
